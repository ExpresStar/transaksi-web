<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RUNNER Approval History</title>
    <link rel="icon" type="image/svg+xml" href="/logo.svg">
    <!-- We will reuse the same stylesheet as the main dashboard to ensure it looks EXACTLY identical -->
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { background-color: #f0f2f5; margin: 0; padding: 0; font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
        .history-container { padding: 20px; }
        .top-actions { display: flex; justify-content: flex-end; margin-bottom: 10px; gap: 8px; }
        .table-wrap { background: #fff; padding: 10px; border-radius: 4px; box-shadow: 0 1px 4px rgba(0,0,0,0.05); }
        .pagination { display: flex; justify-content: center; gap: 5px; margin-top: 15px; }
        .page-btn { height: 28px; min-width: 28px; padding: 0 4px; background: #f4f4f5; border: none; border-radius: 2px; color: #606266; font-size: 13px; cursor: pointer; display: flex; align-items: center; justify-content: center; margin: 0 2px; outline: none; }
        .page-btn.active { background: #409eff; color: #fff; }
        .page-btn:disabled { color: #c0c4cc; cursor: not-allowed; background: #f4f4f5; }
        .page-btn:hover:not(:disabled):not(.active) { color: #409eff; }
        
        /* Utility styles to strictly match the picture */
        .text-red { color: #f56c6c; }
        .badge { display: inline-block; padding: 2px 6px; border-radius: 4px; font-weight: normal; font-size: 11px; }
        .badge.blue { background: #ecf5ff; border: 1px solid #d9ecff; color: #409eff; }
        .badge.green { background: #f0f9eb; border: 1px solid #e1f3d8; color: #67c23a; }
        .badge.gray { background: #f4f4f5; color: #909399; border: 1px solid #d3d4d6; }
        
        .action-btn { font-size: 11px; padding: 4px 10px; border: none; border-radius: 4px; cursor: pointer; color: #fff; min-width: 80px; white-space: nowrap; display: inline-flex; align-items: center; justify-content: center; margin: 2px 0; text-decoration: none; }
        .action-btn.btn-teal { background-color: #00b4a7; }
        .action-btn.btn-green { background-color: #4CAF50; }
        .action-cell { display: flex; flex-direction: column; align-items: center; gap: 4px; }
    </style>
</head>
<body>
    <div class="history-container">
        <!-- Top Filter Buttons Area (from the screenshot) -->
        <div class="top-actions">
            <div style="display: flex; align-items: center; background: #fff; border: 1px solid #dcdfe6; border-radius: 4px; padding: 0 8px; margin-right: 8px;">
                <span style="color: #909399; margin-right: 4px;">🔍</span>
                <input type="text" id="worker-search" placeholder="搜索处理人 (bot/bobi908)" style="border: none; outline: none; padding: 6px 0; font-size: 13px; width: 200px;">
            </div>
            <button class="btn btn-green" onclick="filterByWorker()">🔍 搜索</button>
            <button class="btn btn-orange" onclick="resetFilter()">⟲ 重置</button>
            <button class="btn btn-blue">今天</button>
            <button class="btn btn-gray">昨天</button>
        </div>

        <div class="table-wrap">
            <div class="table-toolbar" style="display: flex; justify-content: flex-end; padding-bottom: 10px; border-bottom: 1px solid #ebeef5; margin-bottom: 10px;">
                <div class="btn-group">
                    <button class="toolbar-btn" onclick="filterByWorker()">🔍</button>
                    <button class="toolbar-btn" id="refresh-history">↻</button>
                    <button class="toolbar-btn">▤ ▾</button>
                    <button class="toolbar-btn">⤓</button>
                </div>
            </div>
            <table class="data-table" id="history-table">
                <thead>
                    <tr>
                        <th>充值单号</th>
                        <th>跑分者</th>
                        <th>跑分者类型</th>
                        <th>充值金额</th>
                        <th>收款账户</th>
                        <th>卡号/虚拟地址</th>
                        <th>银行名称</th>
                        <th>提取状态</th>
                        <th>充值单来源</th>
                        <th>创建时间</th>
                        <th>接单时间</th>
                        <th>转账时间</th>
                        <th>入账时间</th>
                        <th>处理人</th>
                        <th>跑分者等级</th>
                        <th>允许入账时间</th>
                        <th>操作</th>
                        <th>操作2</th>
                    </tr>
                </thead>
                <tbody id="history-tbody">
                    <% if (transactions.length === 0) { %>
                        <tr><td colspan="18" style="text-align: center; padding: 40px; color: #999;">暂无数据</td></tr>
                    <% } %>
                    <% transactions.forEach((tx, i) => { 
                        function fmt(d) {
                            if (!d) return '--';
                            const date = new Date(d);
                            const localTime = new Date(date.getTime() + (7 * 60 * 60 * 1000));
                            const iso = localTime.toISOString();
                            const ymd = iso.split('T')[0];
                            const time = iso.split('T')[1].substring(0, 8);
                            return ymd + ' ' + time;
                        }
                    %>
                    <tr class="tx-row" data-worker="<%= tx.approvedBy %>">
                        <td class="text-red"><%= tx.recharge_no %></td>
                        <td>0931263463</td>
                        <td><span class="badge blue">代付</span></td>
                        <td><%= Number(tx.amount).toLocaleString('vi-VN') %></td>
                        <td><%= tx.receiver_name %></td>
                        <td><%= tx.card_number %></td>
                        <td><%= tx.bank_name %></td>
                        <td><span class="badge blue">取消跟单</span></td>
                        <td><span class="badge blue">商户代理</span></td>
                        <td>
                            <div style="line-height:1.2"><%= fmt(tx.created_at).split(' ')[0] %><br><%= fmt(tx.created_at).split(' ')[1] %></div>
                        </td>
                        <td>1分钟内</td>
                        <td>
                            <div style="line-height:1.2"><%= fmt(tx.created_at).split(' ')[0] %><br><%= fmt(tx.created_at).split(' ')[1] %></div>
                        </td>
                        <td>
                            <div style="line-height:1.2"><%= fmt(tx.updated_at).split(' ')[0] %><br><%= fmt(tx.updated_at).split(' ')[1] %></div>
                        </td>
                        <td class="worker-name"><%= tx.approvedBy %></td>
                        <td><span class="badge green">0.5小时</span></td>
                        <td>
                            <div style="line-height:1.2"><%= fmt(tx.allow_transfer_time).split(' ')[0] %><br><%= fmt(tx.allow_transfer_time).split(' ')[1] %></div>    
                        </td>
                        <td><span class="action-btn btn-green">审签</span></td>
                        <td>
                            <div class="action-cell">
                                <a href="/transaction-detail/<%= tx.id %>" target="_blank" class="action-btn btn-teal">☑ 详情</a>
                            </div>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>

            <!-- Footer Pagination (Static UI to match the screenshot) -->
            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 15px;">
                <div style="font-size: 13px; color: #606266; font-weight: 500;">
                    <span id="mandarin-date-footer"></span> 
                    &nbsp;&nbsp;
                    <span id="total-count-display">共 <%= total %> 条</span>
                </div>
                <!-- Hidden count used by the script -->
                <span id="total-count" style="display:none;"><%= total %></span>
                <div class="pagination">
                    <a href="#" class="page-btn active">1</a>
                    <a href="#" class="page-btn">2</a>
                    <a href="#" class="page-btn">3</a>
                    <a href="#" class="page-btn">4</a>
                    <a href="#" class="page-btn">5</a>
                    <span style="color: #999; padding: 4px;">...</span>
                    <a href="#" class="page-btn"><%= Math.max(1, Math.ceil(total / 10)) %></a>
                </div>
            </div>
        </div>
    </div>

    <script>
        let allHistoryData = [];
        let currentHistoryPage = 1;
        const historyRowsPerPage = 10;
        let isHistoryRefreshing = false;

        const historyTbody = document.getElementById('history-tbody');
        const refreshHistoryBtn = document.getElementById('refresh-history');
        const totalCountDisplay = document.getElementById('total-count-display');
        const paginationContainer = document.querySelector('.pagination');
        const workerSearch = document.getElementById('worker-search');

        function fmtDate(d) {
            if (!d) return '--';
            const date = new Date(d);
            const localTime = new Date(date.getTime() + (7 * 60 * 60 * 1000));
            const iso = localTime.toISOString();
            const ymd = iso.split('T')[0];
            const time = iso.split('T')[1].substring(0, 8);
            return { ymd, time };
        }

        async function fetchHistory(shouldBlink = false) {
            if (isHistoryRefreshing) return;
            isHistoryRefreshing = true;

            try {
                const response = await fetch('/api/history');
                const result = await response.json();

                if (result.success) {
                    allHistoryData = result.data;
                    
                    if (shouldBlink) {
                        historyTbody.classList.remove('blink-data');
                        void historyTbody.offsetWidth;
                        historyTbody.classList.add('blink-data');
                    }

                    renderHistory();
                }
            } catch (err) {
                console.error("Failed to fetch history:", err);
            } finally {
                setTimeout(() => {
                    historyTbody.classList.remove('blink-data');
                    isHistoryRefreshing = false;
                }, 300);
            }
        }

        function renderHistory() {
            const query = workerSearch.value.toLowerCase().trim();
            const filtered = allHistoryData.filter(tx => 
                (tx.approvedBy || '').toLowerCase().includes(query)
            );

            totalCountDisplay.innerText = `共 ${filtered.length} 条`;

            const totalPages = Math.ceil(filtered.length / historyRowsPerPage) || 1;
            if (currentHistoryPage > totalPages) currentHistoryPage = totalPages;

            const start = (currentHistoryPage - 1) * historyRowsPerPage;
            const end = start + historyRowsPerPage;
            const pageData = filtered.slice(start, end);

            let html = '';
            if (pageData.length === 0) {
                html = '<tr><td colspan="18" style="text-align: center; padding: 40px; color: #999;">暂无数据</td></tr>';
            } else {
                pageData.forEach(tx => {
                    const created = fmtDate(tx.created_at);
                    const allow = fmtDate(tx.allow_transfer_time);
                    html += `
                        <tr class="tx-row" data-worker="${tx.approvedBy}">
                            <td class="text-red">${tx.recharge_no}</td>
                            <td>0931263463</td>
                            <td><span class="badge blue">代付</span></td>
                            <td>${Number(tx.amount).toLocaleString('vi-VN')}</td>
                            <td>${tx.receiver_name}</td>
                            <td>${tx.card_number}</td>
                            <td>${tx.bank_name}</td>
                            <td><span class="badge blue">取消跟单</span></td>
                            <td><span class="badge blue">商户代理</span></td>
                            <td><div style="line-height:1.2">${created.ymd}<br>${created.time}</div></td>
                            <td>1分钟内</td>
                            <td><div style="line-height:1.2">${created.ymd}<br>${created.time}</div></td>
                            <td><div style="line-height:1.2">${(() => { const u = fmtDate(tx.updated_at); return u.ymd + '<br>' + u.time; })()}</div></td>
                            <td class="worker-name">${tx.approvedBy}</td>
                            <td><span class="badge green">0.5小时</span></td>
                            <td><div style="line-height:1.2">${allow.ymd}<br>${allow.time}</div></td>
                            <td><span class="action-btn btn-green">审签</span></td>
                            <td><a href="/transaction-detail/${tx.id}" target="_blank" class="action-btn btn-teal" style="text-decoration:none;">☑ 详情</a></td>
                        </tr>
                    `;
                });
            }
            historyTbody.innerHTML = html;
            renderHistoryPagination(totalPages);
        }

        function renderHistoryPagination(totalPages) {
            const container = paginationContainer;
            container.innerHTML = '';
            if (totalPages <= 0) return;

            // Custom Helper for Creating Buttons
            const createNavBtn = (content, targetPage, isActive = false, isDisabled = false) => {
                const btn = document.createElement('button');
                btn.className = `page-btn ${isActive ? 'active' : ''}`;
                btn.innerHTML = content;
                btn.disabled = isDisabled;
                if (!isDisabled && !isActive) {
                    btn.onclick = (e) => {
                        e.preventDefault();
                        currentHistoryPage = targetPage;
                        renderHistory();
                    };
                }
                return btn;
            };

            // 1. First Page
            container.appendChild(createNavBtn('«', 1, false, currentHistoryPage === 1));

            // 2. Previous Page
            container.appendChild(createNavBtn('‹', currentHistoryPage - 1, false, currentHistoryPage === 1));

            // 3. Page Numbers Logic
            let pages = [];
            if (totalPages <= 10) {
                for (let i = 1; i <= totalPages; i++) pages.push(i);
            } else {
                if (currentHistoryPage <= 5) {
                    pages = [1, 2, 3, 4, 5, 6, '...', totalPages];
                } else if (currentHistoryPage >= totalPages - 4) {
                    pages = [1, '...', totalPages - 5, totalPages - 4, totalPages - 3, totalPages - 2, totalPages - 1, totalPages];
                } else {
                    pages = [1, '...', currentHistoryPage - 2, currentHistoryPage - 1, currentHistoryPage, currentHistoryPage + 1, currentHistoryPage + 2, '...', totalPages];
                }
            }

            pages.forEach(p => {
                if (p === '...') {
                    const span = document.createElement('span');
                    span.style.color = '#999';
                    span.style.padding = '4px';
                    span.innerText = '...';
                    container.appendChild(span);
                } else {
                    container.appendChild(createNavBtn(p, p, p === currentHistoryPage));
                }
            });

            // 4. Next Page
            container.appendChild(createNavBtn('›', currentHistoryPage + 1, false, currentHistoryPage === totalPages));

            // 5. Last Page Button
            container.appendChild(createNavBtn('»', totalPages, false, currentHistoryPage === totalPages));
        }

        function filterByWorker() {
            currentHistoryPage = 1;
            renderHistory();
        }

        function resetFilter() {
            workerSearch.value = '';
            currentHistoryPage = 1;
            fetchHistory(true);
        }

        function updateMandarinDate() {
            const now = new Date();
            const mandarinDate = `${now.getFullYear()}年${String(now.getMonth() + 1).padStart(2, '0')}月${String(now.getDate()).padStart(2, '0')}日`;
            document.getElementById('mandarin-date-footer').innerText = mandarinDate;
        }

        refreshHistoryBtn.onclick = () => fetchHistory(true);
        workerSearch.onkeypress = (e) => { if (e.key === 'Enter') filterByWorker(); };

        // Initial setup
        updateMandarinDate();
        // Since EJS already rendered the first batch, we can either use it or just fetch fresh
        // Let's fetch fresh to ensure all JS logic is hooked up correctly
        fetchHistory(false);
    </script>
</body>
</html>
