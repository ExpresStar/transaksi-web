<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Agribank - Giao dịch thành công</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { max-width: 420px; margin: 0 auto; }
    body {
      font-family: Arial, 'Segoe UI', sans-serif;
      background: #f7f3ee;
      min-height: 100vh;
      display: flex; flex-direction: column;
      max-width: 420px;
      margin: 0 auto;
    }
    .nav {
      background: #8B1A1A;
      padding: 14px 16px;
      display: flex; align-items: center;
    }
    .nav-back { color: #fff; font-size: 20px; margin-right: 12px; }
    .nav-title { flex: 1; text-align: center; color: #fff; font-size: 16px; font-weight: 600; margin-right: 28px; }

    .success-banner {
      background: linear-gradient(160deg, #8B1A1A 0%, #B71C1C 60%, #C62828 100%);
      padding: 28px 16px 44px;
      text-align: center; color: white;
    }
    .logo-wrap { display: flex; justify-content: center; margin-bottom: 12px; }
    .logo-wrap img { height: 44px; filter: brightness(10); object-fit: contain; }
    .success-icon {
      width: 58px; height: 58px; background: rgba(255,255,255,0.2);
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      margin: 0 auto 12px; border: 2px solid rgba(255,255,255,0.5);
      font-size: 26px;
    }
    .success-label { font-size: 14px; opacity: 0.85; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 1px; font-weight: 600; }
    .success-amount { font-size: 34px; font-weight: 700; }
    .success-amount .vnd { font-size: 16px; font-weight: 400; opacity: 0.75; }

    .card {
      background: #fff; border-radius: 18px 18px 0 0;
      margin-top: -24px; flex: 1; padding: 22px 20px;
    }

    .section-label {
      font-size: 11px; font-weight: 700; color: #8B1A1A;
      text-transform: uppercase; letter-spacing: 1px;
      margin: 18px 0 10px; padding-bottom: 6px;
      border-bottom: 2px solid #f5dada;
    }
    .row { display: flex; justify-content: space-between; align-items: flex-start; padding: 10px 0; border-bottom: 1px dotted #eeeeee; }
    .row:last-child { border-bottom: none; }
    .row-label { color: #888; font-size: 12.5px; font-weight: 700; max-width: 45%; letter-spacing: 0.2px; }
    .row-value { color: #222; font-size: 13px; text-align: right; max-width: 55%; word-break: break-all; }
    .row-value.amount { color: #8B1A1A; font-size: 15px; font-weight: 700; }
    .row-value.mono { font-family: 'Courier New', monospace; font-size: 12px; color: #555; }
    .badge { display: inline-flex; align-items: center; gap: 4px; background: #fff3cd; color: #856404; border-radius: 4px; padding: 3px 10px; font-size: 12px; font-weight: 700; border: 1px solid #ffc107; }

    .stamp-box {
      border: 2px solid #D32F2F; border-radius: 8px;
      padding: 10px 16px; margin-top: 18px; text-align: center;
      position: relative;
    }
    .stamp-box::before { content: '✔ ĐÃ HOÀN THÀNH'; position: absolute; top: -11px; left: 50%; transform: translateX(-50%); background: #fff; padding: 0 8px; font-size: 11px; font-weight: 700; color: #B71C1C; letter-spacing: 1px; }
    .stamp-ref-label { font-size: 11px; color: #aaa; margin-top: 4px; }
    .stamp-ref { font-family: monospace; font-size: 14px; font-weight: 700; color: #333; letter-spacing: 1px; margin-top: 4px; }

    .footer {
      background: #8B1A1A; color: rgba(255,255,255,0.7);
      text-align: center; padding: 16px; font-size: 11px;
    }
    .footer img { height: 22px; margin-bottom: 6px; filter: brightness(10); }
  </style>
</head>
<body>
  <div class="nav">
    <span class="nav-back">←</span>
    <span class="nav-title">Kết quả giao dịch</span>
  </div>

  <div class="success-banner">
    <div class="logo-wrap"><img src="/logos/agri.svg" alt="Agribank"></div>
    <div class="success-icon">✔</div>
    <div class="success-label">Giao dịch thành công</div>
    <div class="success-amount"><%= Number(transaction.amount).toLocaleString('vi-VN') %> <span class="vnd">VND</span></div>
  </div>

  <div class="card">
    <div class="section-label">Thông tin người nhận</div>
    <div class="row"><span class="row-label">Tên người nhận:</span><span class="row-value"><%= transaction.receiver_name %></span></div>
    <div class="row"><span class="row-label">Số tài khoản:</span><span class="row-value mono"><%= transaction.card_number %></span></div>
    <div class="row"><span class="row-label">Ngân hàng:</span><span class="row-value"><%= transaction.bank_name %></span></div>

    <div class="section-label">Chi tiết giao dịch</div>
    <div class="row"><span class="row-label">Số tiền:</span><span class="row-value amount"><%= Number(transaction.amount).toLocaleString('vi-VN') %> VND</span></div>
    <div class="row"><span class="row-label">Phí:</span><span class="row-value">Miễn phí</span></div>
    <div class="row"><span class="row-label">Nội dung:</span><span class="row-value mono"><%= transaction.recharge_no %></span></div>
    <div class="row"><span class="row-label">Thời gian:</span><span class="row-value"><%
      var d = new Date(transaction.created_at);
      var hh = String(d.getHours()).padStart(2,'0');
      var mi = String(d.getMinutes()).padStart(2,'0');
      var ss = String(d.getSeconds()).padStart(2,'0');
      var dd2 = String(d.getDate()).padStart(2,'0');
      var mm2 = String(d.getMonth()+1).padStart(2,'0');
      var yy2 = d.getFullYear();
    %><%= hh %>:<%= mi %>:<%= ss %><br><%= dd2 %>/<%= mm2 %>/<%= yy2 %></span></div>
    <div class="row"><span class="row-label">Trạng thái:</span><span class="row-value"><span class="badge">✔ Thành công</span></span></div>

    <div class="stamp-box">
      <div class="stamp-ref-label">Mã giao dịch</div>
      <div class="stamp-ref"><%= transaction.order_no %></div>
    </div>
  </div>

  <div class="footer">
    <div><img src="/logos/agri.svg" alt="Agribank"></div>
    Agribank · Mang phồn thịnh đến khách hàng
  </div>
</body>
</html>
